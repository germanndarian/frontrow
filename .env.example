# ──────────────────────────────────────────────────────────────────────────
# Frontrow — environment
#
# IMPORTANT: The data source (ESPN's public endpoints) requires NO API key.
# There is no secret to set to run this app. Everything below is OPTIONAL.
#
# Copy this file to `.env.local` (already git-ignored) to override anything.
# ──────────────────────────────────────────────────────────────────────────

# ESPN base URLs (server-side only). Override only if you proxy them.
ESPN_SITE_API=https://site.api.espn.com/apis/site/v2/sports
ESPN_STANDINGS_API=https://site.api.espn.com/apis/v2/sports
ESPN_WEB_API=https://site.web.api.espn.com/apis/common/v3/sports

# How often the client polls live games, in milliseconds (only while live).
NEXT_PUBLIC_LIVE_POLL_MS=30000

# Set to "true" to run fully offline against the bundled demo dataset
# (no ESPN calls). Handy for development with no network.
NEXT_PUBLIC_USE_MOCK=false

# ──────────────────────────────────────────────────────────────────────────
# Supabase (accounts + saved follows/settings)
#
# In production these are injected by the Supabase Vercel integration. They are
# marked "Sensitive", so `vercel env pull` returns them BLANK — for local dev,
# copy the two public client values from the Supabase dashboard
# (Project Settings → API) into .env.local:
#
#   NEXT_PUBLIC_SUPABASE_URL=https://<ref>.supabase.co
#   NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon / publishable key>
#
# SUPABASE_SERVICE_ROLE_KEY is server-only (used by /api/account to delete a
# user) and lives on Vercel — never expose it to the browser.
# ──────────────────────────────────────────────────────────────────────────
